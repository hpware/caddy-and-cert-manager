BETTER_AUTH_SECRET=
NEXT_PUBLIC_URL=http://localhost:3000
# NEXT_PUBLIC_GUEST_RESOURCES_HOST is the hostname used for guest resource access.
# The example value (a.dev.yhw.tw) must resolve to your local dev host. If it
# does not already, add an entry to your /etc/hosts file: 127.0.0.1 a.dev.yhw.tw
# NEXT_PUBLIC_GUEST_RESOURCES_URL should use the same hostname with the app port.
NEXT_PUBLIC_GUEST_RESOURCES_HOST=a.dev.yhw.tw
NEXT_PUBLIC_GUEST_RESOURCES_URL=http://a.dev.yhw.tw:3000

DATABASE_URL=postgresql://user:user@localhost/db
#CADDY_API_SERVER="http://localhost:2019"
## SSO
NEXT_PUBLIC_SSO_ENABLE=true
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_DISCOVERY_URL=

# FOR GENERIC HOME LAB USE, IT IS SAFE TO SET TO true
IGNORE_PROTECTIONS=false
